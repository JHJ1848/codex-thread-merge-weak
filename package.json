{
  "name": "codex-project-thread-merge",
  "version": "0.1.0",
  "private": true,
  "description": "Local stdio MCP server and skill for merging Codex project threads into a canonical session.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "node ./node_modules/tsx/dist/cli.mjs src/server/index.ts",
    "generate:bindings": "codex app-server generate-ts --experimental --out src/generated/app-server",
    "test": "node ./node_modules/tsx/dist/cli.mjs --test src/**/*.test.ts",
    "script:install": "powershell -ExecutionPolicy Bypass -File .\\scripts\\install.ps1",
    "script:update": "powershell -ExecutionPolicy Bypass -File .\\scripts\\update.ps1",
    "script:publish": "powershell -ExecutionPolicy Bypass -File .\\scripts\\publish.ps1",
    "script:register-mcp": "powershell -ExecutionPolicy Bypass -File .\\scripts\\register-mcp.ps1",
    "script:install-skill": "powershell -ExecutionPolicy Bypass -File .\\scripts\\install-skill.ps1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3"
  }
}
